#!/usr/bin/env bash

set -euo pipefail

message="${1:-Needs attention}"

title="Terminal"
if [[ -n "${TMUX:-}" ]] && command -v tmux >/dev/null 2>&1; then
    pane_index="$(tmux display-message -p -t "${TMUX_PANE:-}" '#I' 2>/dev/null || echo '?')"
    pane_path="$(tmux display-message -p -t "${TMUX_PANE:-}" '#{?#{==:#{pane_current_path},#{HOME}},~,#{b:pane_current_path}}' 2>/dev/null || echo '~')"
    title="Pane ${pane_index}: ${pane_path}"
fi

case "$(uname -s)" in
    Darwin)
        if command -v osascript >/dev/null 2>&1; then
            osascript -e 'on run argv' \
                -e 'display notification (item 2 of argv) with title (item 1 of argv)' \
                -e 'end run' \
                "$title" "$message"
            exit 0
        fi
        ;;
    Linux)
        if command -v notify-send >/dev/null 2>&1; then
            notify-send "$title" "$message"
            exit 0
        fi
        ;;
esac

printf '\a'
printf '%s: %s\n' "$title" "$message" >&2
